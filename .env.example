# ─────────────────────────────────────────────────────────────
# AI Project-Roadmap Generator — environment reference
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# MongoDB — Prisma datasource. For Atlas, prefer the non-SRV (direct) form to
# avoid DNS SRV-lookup issues:
#   mongodb://USER:PASS@host1:27017,host2:27017,host3:27017/DBNAME?ssl=true&replicaSet=...&authSource=admin
# Local dev example:
MONGODB_URI=mongodb://localhost:27017/ai_roadmap_dev

# JWT — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-random-hex-string
JWT_REFRESH_SECRET=another-different-64-char-random-hex-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Groq — get from console.groq.com -> API Keys (free) [not used yet]
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096

# Email (Nodemailer) — Gmail App Password for local dev [not used yet]
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@ai-roadmap.com

# App
NODE_ENV=development
API_PORT=4000
FRONTEND_URL=http://localhost:3000
